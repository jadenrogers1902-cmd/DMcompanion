# Supabase — copy this file to .env.local and fill in your values
# Find these in your Supabase project dashboard under Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Backward compatibility: NEXT_PUBLIC_SUPABASE_ANON_KEY is also supported.

# SERVER-ONLY service-role key. Required for the Notion integration (it reads the
# server-only Notion token table that RLS hides from all clients).
# NEVER prefix this with NEXT_PUBLIC_ and never use it in client code — it
# bypasses Row Level Security. Found under Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OPTIONAL, SERVER-ONLY. Notion webhook verification token for auto-sync
# (Phase 10). Set this to the verification token Notion issues when you create a
# webhook subscription pointing at /api/notion/webhook. Leave unset to disable
# the webhook receiver entirely (manual sync still works). Never NEXT_PUBLIC_.
NOTION_WEBHOOK_SECRET=your-notion-webhook-verification-token

# OPTIONAL LOCAL/CI AUTOMATION. Used by `npm run db:migrate` to link and push
# Supabase migrations without opening the SQL editor. Keep both values secret.
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_DB_PASSWORD=your-supabase-database-password

# OPTIONAL AUTHENTICATED E2E QA. Use a disposable test DM and campaign.
# `npm run test:e2e:auth` fails fast with a clear message if these are unset.
E2E_DM_EMAIL=dm-test@example.com
E2E_DM_PASSWORD=your-test-password
E2E_CAMPAIGN_ID=00000000-0000-0000-0000-000000000000
E2E_ALLOW_CLEAR_BOARD=false
E2E_CLEAR_FROM_POPUP=false
